timezone: Europe/Rome

# Configuration for the `tools` subcommand
tools:
  - name: wut
    description: Explain acronyms
    url: https://github.com/insomniacslk/wut
  - name: lol
    description: Provides shortcuts in a browser
    url: https://github.com/insomniacslk/lol

# Configuration for the `omg` subcommand
omg:
  template: ~/.config/sre/omg.template

# pagerduty configuration
pagerduty:
  user_token: your_token_here
  teams: your-pagerduty-team-name

oncall:
  default_query: your oncall schedule name
  default_schedule: <your pagerduty schedule ID>
  default_schedule_duration: 168h # how far in the future we want to see the schedule. In Go duration format

  # Synonym groups for `oncall shortlist` matching. Searching any term in a
  # group matches entries tagged with any other term in it, in either direction.
  # Matching ignores case and separators, so "bare-metal" == "baremetal" even
  # without a synonym entry; use synonyms for abbreviations/aliases that aren't
  # just punctuation, e.g. bm -> baremetal or k8s -> kubernetes. Edit freely.
  synonyms:
    - [k8s, kubernetes, kube]
    - [baremetal, bm, bare-metal]
    - [storage, disk, nvme]
    - [network, networking, net]

  # Curated component -> schedule mapping for the `oncall shortlist` (alias `sl`)
  # subcommand. Each entry resolves to a PagerDuty schedule either by a free-text
  # `query` (like `oncall search`) or a pinned `schedule_id` (takes precedence).
  # The [filter] argument is matched (fuzzily, and synonym-aware) against each
  # entry's `name`, `component` and `aliases`, e.g. `sre oncall shortlist k8s`.
  # Use -e/--exact for whole-term matches and -s/--case-sensitive to require
  # matching case. Replace the placeholders below with your own teams.
  shortlist:
    - name: Application / Services
      component: app
      aliases: [services, backend]
      query: Application Team On-Call
    - name: Hardware / Provisioning
      component: hardware
      aliases: [bare-metal, provisioning]
      query: Hardware Team On-Call
    - name: Kubernetes / Platform
      component: platform
      aliases: [k8s, kubernetes]
      query: Platform Team On-Call
    - name: Networking
      component: network
      query: Network Team On-Call
    - name: Storage
      component: storage
      query: Storage Team On-Call
    - name: Security
      component: security
      query: Security Team On-Call
    - name: Incident response
      component: incident
      schedule_id: <your pagerduty schedule ID>
